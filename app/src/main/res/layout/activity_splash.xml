<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0D0F"
    android:fitsSystemWindows="true">

    <!-- CENTER BRAND -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toTopOf="@id/ll_footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Logo Box -->
        <FrameLayout
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/bg_splash_logo"
            android:elevation="16dp">
            
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" />
        </FrameLayout>

        <!-- Frexa Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Frexa"
            android:textColor="#FFFFFF"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="-0.03" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Simulasi Trading Crypto"
            android:textColor="#9AA4AD"
            android:textSize="13sp"
            android:letterSpacing="0.01" />

        <!-- Pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_splash_pill">
            
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/shape_dot_green" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paper trading · 24/7"
                android:textColor="#3DD68C"
                android:textSize="10.5sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- FOOTER -->
    <LinearLayout
        android:id="@+id/ll_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="44dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Loader Dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/shape_dot_gold_100" />
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginStart="7dp"
                android:background="@drawable/shape_dot_gold_50" />
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginStart="7dp"
                android:background="@drawable/shape_dot_gold_22" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-monospace"
            android:text="VERSI 1.0"
            android:textColor="#5C666F"
            android:textSize="10sp"
            android:letterSpacing="0.06" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
