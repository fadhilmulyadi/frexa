<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:fillViewport="false">

    <LinearLayout
        android:id="@+id/dialog_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_success"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <!-- Badge -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal">

            <View
                android:id="@+id/badge_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_badge_success"/>

            <ImageView
                android:id="@+id/badge_icon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_check_order"/>
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/schibsted_grotesk"
            android:gravity="center"
            android:textColor="@color/frx_text"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_dialog_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:textColor="@color/frx_text_2"
            android:textSize="12.5sp"/>

        <!-- SUCCESS SUMMARY -->
        <LinearLayout
            android:id="@+id/summary_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_bg_inner"
            android:orientation="vertical"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_qty_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jumlah"
                    android:textColor="@color/frx_text_2"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tv_qty_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_text"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Harga eksekusi"
                    android:textColor="@color/frx_text_2"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tv_exec_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_text"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fee taker (0,15%)"
                    android:textColor="@color/frx_text_2"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tv_dialog_fee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_text"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="11dp"
                android:background="@color/frx_hairline"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_total_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total dibayar"
                    android:textColor="@color/frx_text"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_dialog_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_amber"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Realized P&L row (sell only) -->
            <LinearLayout
                android:id="@+id/row_pnl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:orientation="horizontal"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Realized P&amp;L"
                    android:textColor="@color/frx_text_2"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tv_pnl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- FAILED SUMMARY -->
        <LinearLayout
            android:id="@+id/summary_failed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_bg_inner"
            android:orientation="vertical"
            android:padding="15dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total dibutuhkan"
                    android:textColor="@color/frx_text_2"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tv_needed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_text"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kas tersedia"
                    android:textColor="@color/frx_text_2"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tv_available"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_text"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="11dp"
                android:background="@color/frx_hairline"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kekurangan"
                    android:textColor="@color/frx_down"
                    android:textSize="12.5sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_shortage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/spline_sans_mono"
                    android:textColor="@color/frx_down"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Error note (failed only) -->
        <LinearLayout
            android:id="@+id/error_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_error_note"
            android:gravity="top"
            android:orientation="horizontal"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/spline_sans_mono"
                android:text="!"
                android:textColor="@color/frx_down"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_error_note"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:lineSpacingMultiplier="1.5"
                android:textColor="#D6A6A2"
                android:textSize="10.5sp"/>
        </LinearLayout>

        <!-- TX ID + time row (success only) -->
        <LinearLayout
            android:id="@+id/row_tx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_tx_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/spline_sans_mono"
                android:textColor="@color/frx_text_3"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tv_tx_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/spline_sans_mono"
                android:textColor="@color/frx_text_3"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Primary button -->
        <TextView
            android:id="@+id/btn_dialog_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_btn_buy"
            android:fontFamily="@font/schibsted_grotesk"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:text="Selesai"
            android:textColor="#07130C"
            android:textSize="14.5sp"
            android:textStyle="bold"/>

        <!-- Secondary action -->
        <TextView
            android:id="@+id/tv_secondary_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/schibsted_grotesk"
            android:gravity="center"
            android:paddingBottom="4dp"
            android:text="Lihat di Riwayat"
            android:textColor="@color/frx_amber"
            android:textSize="12.5sp"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
