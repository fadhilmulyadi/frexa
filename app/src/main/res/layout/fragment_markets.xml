<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/frx_bg"
    android:orientation="vertical">

    <!-- Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_markets"
            android:textColor="@color/frx_text"
            android:textSize="21sp"
            android:fontFamily="@font/schibsted_grotesk"
            android:textStyle="bold" />

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hint_search_coin"
                android:textColor="@color/frx_text_3"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Macro stat cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_btc_dominance"
                android:textColor="@color/frx_text_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_btc_dominance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="--"
                android:textColor="@color/frx_text"
                android:textSize="18sp"
                android:fontFamily="@font/spline_sans_mono"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_fear_greed"
                android:textColor="@color/frx_text_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_fear_greed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="--"
                android:textColor="@color/frx_amber"
                android:textSize="18sp"
                android:fontFamily="@font/spline_sans_mono"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_fear_greed_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="--"
                android:textColor="@color/frx_text_2"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_global_mcap"
                android:textColor="@color/frx_text_2"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_global_mcap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="--"
                android:textColor="@color/frx_text"
                android:textSize="18sp"
                android:fontFamily="@font/spline_sans_mono"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tab_gainers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp"
            android:text="@string/tab_top_gainers"
            android:textColor="@color/frx_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_losers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp"
            android:text="@string/tab_top_losers"
            android:textColor="@color/frx_text_3"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tab_volume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_volume"
            android:textColor="@color/frx_text_3"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/frx_hairline" />

    <!-- Coin list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_coins"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingVertical="4dp" />

    <TextView
        android:id="@+id/tv_timestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:textColor="@color/frx_text_3"
        android:textSize="10sp"
        android:fontFamily="@font/spline_sans_mono" />
</LinearLayout>
