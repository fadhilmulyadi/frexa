<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/frx_bg"
    android:orientation="vertical">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/btn_avatar_container"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_surface"
            android:padding="6dp">
            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="match_parent"
                android:layout_height="parent"
                android:src="@drawable/ic_person"
                android:contentDescription="Avatar"
                app:tint="@color/frx_text_2" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/frx_text_2"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/frx_text"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btn_wallet"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_chip_active"
            android:padding="8dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_wallet"
                android:contentDescription="Wallet"
                app:tint="@color/frx_cta_text" />
        </FrameLayout>
    </RelativeLayout>

    <!-- Chart -->
    <com.diellabs.frexa.ui.terminal.CandlestickChartView
        android:id="@+id/chart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/frx_surface"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Mode & Profit -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="Mode Fixed Time"
                android:textColor="@color/frx_text_2"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_profit_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Profit: +Đ0,95"
                android:textColor="@color/frx_green"
                android:textSize="13sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Row 2: Steppers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <!-- Duration Stepper -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_surface_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btn_duration_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_minus"
                    android:contentDescription="Minus Duration"
                    app:tint="@color/frx_text_2" />

                <LinearLayout
                    android:id="@+id/btn_duration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Durasi"
                        android:textColor="@color/frx_text_3"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tv_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 mnt"
                        android:textColor="@color/frx_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_duration_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_plus"
                    android:contentDescription="Plus Duration"
                    app:tint="@color/frx_text_2" />
            </LinearLayout>

            <!-- Amount Stepper -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_surface_2"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <ImageButton
                    android:id="@+id/btn_stake_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_minus"
                    android:contentDescription="Minus Amount"
                    app:tint="@color/frx_text_2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Investasi"
                        android:textColor="@color/frx_text_3"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/tv_stake"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đ1,00"
                        android:textColor="@color/frx_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_stake_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_plus"
                    android:contentDescription="Plus Amount"
                    app:tint="@color/frx_text_2" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_down"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:backgroundTint="@color/frx_down"
                android:text="Turun"
                android:textAllCaps="false"
                android:textColor="#fff"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <ImageButton
                android:id="@+id/btn_chart_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_surface_2"
                android:padding="12dp"
                android:src="@drawable/ic_clock"
                android:contentDescription="Settings"
                app:tint="@color/frx_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_up"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:backgroundTint="@android:color/transparent"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@null"
                android:background="@drawable/btn_cta_grad"
                android:text="Naik"
                android:textAllCaps="false"
                android:textColor="@color/frx_cta_text"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/tv_offline"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/frx_down" android:textColor="#fff"
        android:padding="8dp" android:gravity="center"
        android:text="@string/banner_offline" android:visibility="gone" />

</LinearLayout>
