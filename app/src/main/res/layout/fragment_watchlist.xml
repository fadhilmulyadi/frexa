<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/frx_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_watchlist"
            android:textColor="@color/frx_text"
            android:textSize="21sp"
            android:fontFamily="@font/schibsted_grotesk"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_watchlist_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 KOIN · LIVE"
            android:textColor="@color/frx_text_3"
            android:textSize="10sp"
            android:fontFamily="@font/spline_sans_mono" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <LinearLayout
                android:id="@+id/watchlist_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Belum ada koin di watchlist"
                android:textColor="@color/frx_text_3"
                android:textSize="13sp"
                android:gravity="center" />

            <!-- Add coin button -->
            <LinearLayout
                android:id="@+id/btn_add_coin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_dashed_border"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+  Tambah koin"
                    android:textColor="@color/frx_text_2"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
