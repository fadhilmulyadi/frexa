<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:elevation="4dp"
    android:orientation="horizontal">

    <!-- Colored left border bar -->
    <View
        android:id="@+id/snack_border"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/frx_up"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp">

            <View
                android:id="@+id/snack_icon_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_badge_success"/>

            <ImageView
                android:id="@+id/snack_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_check_order"/>
        </FrameLayout>

        <!-- Text column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/snack_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/schibsted_grotesk"
                android:textColor="@color/frx_text"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/snack_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/spline_sans_mono"
                android:textColor="@color/frx_text_2"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Action -->
        <TextView
            android:id="@+id/snack_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:fontFamily="@font/schibsted_grotesk"
            android:textColor="@color/frx_amber"
            android:textSize="11.5sp"
            android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
